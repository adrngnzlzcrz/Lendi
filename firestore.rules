rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(data) {
      return isSignedIn() && data.createdBy == request.auth.uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Client Helpers ---
    function isValidClient(data) {
      return data.keys().hasAll(['clientNumber', 'name', 'createdBy', 'createdAt'])
        && data.clientNumber is string && data.clientNumber.size() <= 20
        && data.name is string && data.name.size() <= 100 && data.name.size() > 0
        && data.createdBy is string
        && data.createdAt == request.time;
    }

    // --- Loan Helpers ---
    function isValidLoan(data) {
      return data.keys().hasAll(['clientId', 'clientName', 'amount', 'interestRate', 'penaltyRate', 'totalDebt', 'remainingBalance', 'status', 'createdBy', 'createdAt'])
        && data.clientId is string && data.amount is number && data.amount > 0
        && data.remainingBalance is number
        && data.status in ['active', 'paid', 'default']
        && data.createdBy is string
        && data.createdAt == request.time;
    }

    // --- Payment Helpers ---
    function isValidPayment(data) {
      return data.keys().hasAll(['paymentNumber', 'loanId', 'clientId', 'amount', 'penaltyApplied', 'interestApplied', 'previousBalance', 'newBalance', 'date', 'createdBy'])
        && data.paymentNumber is string && data.loanId is string && data.clientId is string
        && data.amount is number && data.amount > 0
        && data.createdBy is string
        && data.date == request.time;
    }

    // --- Collections ---

    match /clients/{clientId} {
      allow get: if true;
      allow list: if true;
      allow create: if isValidId(clientId) && isValidClient(incoming());
      allow update: if true && isValidClient(incoming())
        && incoming().clientNumber == existing().clientNumber; // Immutable ID
    }

    match /loans/{loanId} {
      allow get: if true;
      allow list: if true;
      allow create: if isValidId(loanId) && isValidLoan(incoming())
        && exists(/databases/$(database)/documents/clients/$(incoming().clientId));
      allow update: if true && isValidLoan(incoming())
        && incoming().clientId == existing().clientId;
    }

    match /payments/{paymentId} {
      allow get: if true;
      allow list: if true;
      allow create: if isValidId(paymentId) && isValidPayment(incoming())
        && exists(/databases/$(database)/documents/loans/$(incoming().loanId));
    }

    match /settings/counters {
      allow get: if true;
      allow write: if true;
    }
  }
}
